# Copy this file to .env.local and fill in the values.
# Anything left blank will keep the app running in MOCK_MODE (no network calls).

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used by Telegram webhook registration).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Force mock mode regardless of other env vars. "true" | "false".
# When unset, mock mode auto-enables if required keys are missing.
MOCK_MODE=""

# ─── Z.AI GLM ─────────────────────────────────────────────────────────────────
# From https://open.bigmodel.cn/ (Z.AI console).
ZAI_API_KEY=""
# Model id, e.g. "glm-4.6" or "glm-4-flash". Defaults to glm-4.6 in code.
ZAI_MODEL=""
# Optional base URL override; leave blank for the default Z.AI endpoint.
ZAI_BASE_URL=""

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
# Postgres connection string (Project Settings → Database → Connection string → URI).
# Used by the LangGraph checkpointer.
SUPABASE_DB_URL=""

# ─── Telegram ─────────────────────────────────────────────────────────────────
# From @BotFather.
TELEGRAM_BOT_TOKEN=""
# Arbitrary shared secret; Telegram echoes it on each webhook call so we can verify.
TELEGRAM_WEBHOOK_SECRET=""

# ─── LangGraph service (Phase 7+) ─────────────────────────────────────────────
# URL of the Python FastAPI sidecar that hosts the triage graph.
LANGGRAPH_SERVICE_URL=""
