# Copy this file to .env.local and fill in the values.
# When ANTHROPIC_API_KEY is missing the app boots in MOCK_MODE
# (fixtures only, no network calls).

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used by Telegram webhook registration).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Force mock mode regardless of other env vars. "true" | "false".
# When unset, mock mode auto-enables if ANTHROPIC_API_KEY is missing.
MOCK_MODE=""

# ─── Clinic identity (single-tenant deploy) ───────────────────────────────────
# These drive the user-visible clinic name, doctor, and emergency phone across
# both server (lib/env.ts ENV.clinic) and client (lib/clinic.ts CLINIC).
# Defaults match the demo Peng Aun identity so the app builds without these set.
# For client-side rendering use the NEXT_PUBLIC_* mirrors — Next inlines those
# at build, so they MUST be present in the deployment env when you build the app.
NEXT_PUBLIC_CLINIC_ID=""
NEXT_PUBLIC_CLINIC_NAME=""
NEXT_PUBLIC_CLINIC_DOCTOR=""
NEXT_PUBLIC_CLINIC_PHONE=""
# Server-only fallbacks (rarely needed — the NEXT_PUBLIC_* values cover both sides):
CLINIC_ID=""
CLINIC_NAME=""
CLINIC_DOCTOR=""
CLINIC_PHONE=""

# ─── Anthropic (reasoning + vision) ───────────────────────────────────────────
# From https://console.anthropic.com/. Required to leave mock mode.
ANTHROPIC_API_KEY=""
# Per-feature model override (defaults baked in code):
#   brief   → claude-haiku-4-5-20251001  (cheap, fast, 5-line summary)
#   consult → claude-sonnet-4-6           (strict JSON + tool-use)
#   triage  → claude-sonnet-4-6           (vision + multi-turn tool use)
ANTHROPIC_MODEL_BRIEF=""
ANTHROPIC_MODEL_CONSULT=""
ANTHROPIC_MODEL_TRIAGE=""

# ─── Deepgram (speech-to-text) ────────────────────────────────────────────────
# From https://console.deepgram.com/. $200 free credit on signup.
DEEPGRAM_API_KEY=""
# Defaults to nova-3.
DEEPGRAM_MODEL=""

# ─── Tavily (web search tool) ─────────────────────────────────────────────────
# From https://app.tavily.com/. 1k free searches/month.
# Optional — when missing, the LLM tool registry omits tavily_search and
# the model proceeds without web context.
TAVILY_API_KEY=""

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://ococxqgjfqynhbxmnaos.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""
# Postgres connection string (Project Settings → Database → Connection string → URI).
SUPABASE_DB_URL=""

# ─── Telegram ─────────────────────────────────────────────────────────────────
# From @BotFather.
TELEGRAM_BOT_TOKEN=""
# Arbitrary shared secret; Telegram echoes it on each webhook call so we can
# verify. REQUIRED in production — the webhook route refuses to serve when
# NODE_ENV=production and this is unset (see app/api/telegram/webhook/route.ts).
TELEGRAM_WEBHOOK_SECRET=""

# ─── LangGraph service (Phase 7+) ─────────────────────────────────────────────
# URL of the Python FastAPI sidecar that hosts the triage graph.
LANGGRAPH_SERVICE_URL=""
